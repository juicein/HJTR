<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>四川昱彻建筑工程有限公司</title>

<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{

font-family:"Noto Sans SC",sans-serif;
background:#f5f7fb;
color:#333;
line-height:1.8;
}

a{
text-decoration:none;
color:inherit;
}

header{

position:fixed;
top:0;
left:0;
right:0;
height:72px;

background:rgba(6,28,56,.92);

backdrop-filter:blur(20px);

display:flex;
justify-content:space-between;
align-items:center;

padding:0 70px;

z-index:999;

box-shadow:0 4px 20px rgba(0,0,0,.18);

}

.logo{

font-size:28px;

font-weight:900;

color:#fff;

letter-spacing:2px;

}

.logo span{

color:#D7B26D;

}

nav{

display:flex;
gap:40px;

}

nav a{

color:#fff;
font-size:15px;
position:relative;
transition:.3s;

}

nav a:after{

content:"";
position:absolute;
bottom:-8px;
left:0;
width:0;
height:2px;
background:#D7B26D;
transition:.3s;

}

nav a:hover{

color:#D7B26D;

}

nav a:hover:after{

width:100%;

}

.hero{

height:720px;

background:
linear-gradient(rgba(4,22,48,.72),rgba(4,22,48,.72)),
url("https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=2000&q=80");

background-size:cover;
background-position:center;

display:flex;
align-items:center;

padding-left:120px;

color:white;

}

.hero-content{

max-width:720px;

}

.hero h1{

font-size:60px;
font-weight:900;
margin-bottom:20px;

}

.hero p{

font-size:20px;
opacity:.95;
margin-bottom:35px;

}

.btn{

display:inline-block;

padding:15px 42px;

background:#D7B26D;

border-radius:50px;

color:white;

font-weight:bold;

transition:.35s;

}

.btn:hover{

transform:translateY(-3px);

box-shadow:0 12px 30px rgba(215,178,109,.35);

}

section{

padding:90px 10%;

}

.title{

font-size:36px;

font-weight:800;

color:#123A6B;

margin-bottom:25px;

position:relative;

padding-left:18px;

}

.title:before{

content:"";

position:absolute;
left:0;
top:8px;

width:6px;
height:42px;

background:#D7B26D;

border-radius:30px;

}

.intro{

display:grid;
grid-template-columns:1.3fr .7fr;
gap:50px;

align-items:center;

}

.intro img{

width:100%;
border-radius:16px;
box-shadow:0 25px 50px rgba(0,0,0,.15);

}

.card{

background:white;

padding:40px;

border-radius:20px;

box-shadow:0 20px 50px rgba(0,0,0,.08);

}

.card p{

margin-bottom:18px;

}

.ethics{

background:#0F2746;

color:white;

}

.ethics .title{

color:white;

}

.ethics .title:before{

background:#D7B26D;

}

.ethics-box{

display:grid;

grid-template-columns:repeat(4,1fr);

gap:30px;

margin-top:50px;

}

.item{

background:rgba(255,255,255,.08);

border:1px solid rgba(255,255,255,.1);

padding:35px;

border-radius:18px;

transition:.35s;

}

.item:hover{

transform:translateY(-8px);

background:rgba(255,255,255,.12);

}

.item h3{

margin-bottom:15px;

color:#D7B26D;

}

.service{

display:grid;

grid-template-columns:repeat(3,1fr);

gap:28px;

margin-top:50px;

}

.service-card{

background:white;

padding:35px;

border-radius:18px;

transition:.3s;

box-shadow:0 10px 35px rgba(0,0,0,.08);

}

.service-card:hover{

transform:translateY(-10px);

}

.service-card h3{

color:#123A6B;

margin-bottom:12px;

}

.vision{

background:linear-gradient(120deg,#123A6B,#0A1F38);

color:white;

text-align:center;

}

.vision h2{

font-size:42px;

margin-bottom:20px;

}

.vision p{

max-width:900px;

margin:auto;

font-size:18px;

}

footer{

background:#071628;

color:#ccc;

padding:50px;

text-align:center;

font-size:14px;

}

@media(max-width:980px){

.hero{

padding:40px;

height:600px;

}

.hero h1{

font-size:40px;

}

.intro{

grid-template-columns:1fr;

}

.ethics-box{

grid-template-columns:1fr;

}

.service{

grid-template-columns:1fr;

}

header{

padding:0 20px;

}

nav{

display:none;

}

}

</style>
</head>

